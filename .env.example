# Database
DATABASE_URL=postgresql://user:password@localhost:5432/jtransfer

# CORS
CORS_ORIGINS=http://localhost:5173

# Server
PORT=3000

# Cloudflare R2 Storage
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=jtransfer

# Optional: Max file size in bytes (default: 1GB)
# MAX_FILE_SIZE=1073741824

# Optional: Redis for rate limiting (falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379

# Rate Limits (all optional, shown with defaults)
# RATE_LIMIT_UPLOADS_PER_MINUTE=5      # Upload requests per minute per IP
# RATE_LIMIT_DOWNLOADS_PER_MINUTE=20   # Download requests per minute per IP
# RATE_LIMIT_DAILY_TRANSFERS=20        # New transfers per day per IP
# RATE_LIMIT_DAILY_DOWNLOADS=200       # File downloads per day per IP
# RATE_LIMIT_MONTHLY_UPLOAD_GB=2       # Total upload volume per month per IP (in GB)
